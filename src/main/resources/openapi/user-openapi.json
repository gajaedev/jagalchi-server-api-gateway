{
  "openapi": "3.0.1",
  "info": {
    "title": "Jagalchi User API",
    "version": "v1.0.0",
    "description": "유저/인증 API"
  },
  "servers": [
    {
      "url": "/",
      "description": "Gateway Server"
    }
  ],
  "paths": {
    "/users": {
      "get": {
        "summary": "이름으로 유저 조회",
        "parameters": [
          {
            "name": "name",
            "in": "query",
            "required": true,
            "schema": { "type": "string" }
          }
        ],
        "responses": { "200": { "description": "OK" } }
      },
      "post": {
        "summary": "회원가입",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "email": { "type": "string" },
                  "name": { "type": "string" },
                  "password": { "type": "string" }
                }
              }
            }
          }
        },
        "responses": { "201": { "description": "Created" } }
      },
      "delete": {
        "summary": "회원 탈퇴",
        "responses": { "204": { "description": "No Content" } }
      }
    },
    "/users/auth/login": {
      "post": {
        "summary": "이메일 로그인",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "email": { "type": "string" },
                  "password": { "type": "string" }
                }
              }
            }
          }
        },
        "responses": { "200": { "description": "OK (accessToken + refreshToken)" } }
      }
    },
    "/users/auth/login/google": {
      "get": {
        "summary": "구글 로그인 시작",
        "responses": { "302": { "description": "Redirect" } }
      }
    },
    "/users/auth/login/github": {
      "get": {
        "summary": "깃허브 로그인 시작",
        "responses": { "302": { "description": "Redirect" } }
      }
    },
    "/users/auth/password-reset": {
      "post": {
        "summary": "비밀번호 재설정 인증코드 발송",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": { "email": { "type": "string" } }
              }
            }
          }
        },
        "responses": { "200": { "description": "OK" } }
      },
      "patch": {
        "summary": "비밀번호 변경",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "email": { "type": "string" },
                  "newPassword": { "type": "string" }
                }
              }
            }
          }
        },
        "responses": { "200": { "description": "OK" } }
      }
    },
    "/users/auth/password-reset/verify": {
      "patch": {
        "summary": "비밀번호 재설정 인증코드 검증",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "email": { "type": "string" },
                  "code": { "type": "string" }
                }
              }
            }
          }
        },
        "responses": { "200": { "description": "OK" } }
      }
    },
    "/users/auth/refresh": {
      "patch": {
        "summary": "액세스 토큰 재발급",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": { "refreshToken": { "type": "string" } }
              }
            }
          }
        },
        "responses": { "200": { "description": "OK (accessToken + refreshToken)" } }
      }
    },
    "/users/me": {
      "get": {
        "summary": "현재 로그인 사용자 조회",
        "responses": { "200": { "description": "OK" } }
      }
    },
    "/users/profile": {
      "patch": {
        "summary": "프로필 수정",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "type": "object" }
            }
          }
        },
        "responses": { "200": { "description": "OK" } }
      }
    },
    "/users/verification": {
      "post": {
        "summary": "회원가입 인증코드 발송",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": { "email": { "type": "string" } }
              }
            }
          }
        },
        "responses": { "200": { "description": "OK" } }
      },
      "patch": {
        "summary": "회원가입 인증코드 검증",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "email": { "type": "string" },
                  "code": { "type": "string" }
                }
              }
            }
          }
        },
        "responses": { "200": { "description": "OK" } }
      }
    },
    "/users/{name}/follow": {
      "patch": {
        "summary": "팔로우/언팔로우",
        "parameters": [
          {
            "name": "name",
            "in": "path",
            "required": true,
            "schema": { "type": "string" }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": { "toggle": { "type": "boolean" } }
              }
            }
          }
        },
        "responses": { "200": { "description": "OK" } }
      }
    },
    "/users/{name}/followers": {
      "get": {
        "summary": "팔로워 목록 조회",
        "parameters": [
          {
            "name": "name",
            "in": "path",
            "required": true,
            "schema": { "type": "string" }
          }
        ],
        "responses": { "200": { "description": "OK" } }
      }
    },
    "/users/{name}/followings": {
      "get": {
        "summary": "팔로잉 목록 조회",
        "parameters": [
          {
            "name": "name",
            "in": "path",
            "required": true,
            "schema": { "type": "string" }
          }
        ],
        "responses": { "200": { "description": "OK" } }
      }
    }
  }
}
